---
import Layout from '../layouts/Layout.astro'
import Preloader from '../components/Preloader.astro'
import Navbar from '../components/Navbar.astro'
import HeroSection from '../components/HeroSection.astro'
import TrustBar from '../components/TrustBar.astro'
import ChapterOne from '../components/ChapterOne.astro'
import ChapterTwo from '../components/ChapterTwo.astro'
import ChapterThree from '../components/ChapterThree.astro'
import FlagInterstitial from '../components/FlagInterstitial.astro'
import TestimonialsSection from '../components/TestimonialsSection.astro'
import BookingSection from '../components/BookingSection.astro'
import Footer from '../components/Footer.astro'
import ScrollAnimations from '../components/ScrollAnimations.astro'
---
<Layout
  title="French Tutoring for Kids"
  description="One-to-one online French lessons for children from Junior Kindergarten through Grade 5. Book a free intro call with Naya today."
>
  <Preloader />
  <ScrollAnimations />
  <Navbar />
  <main id="main-content">
    <HeroSection />
    <TrustBar />
    <ChapterOne />
    <ChapterTwo />
    <ChapterThree />
    <FlagInterstitial />
    <TestimonialsSection />
    <!-- cream → marigold: tall gradient pulled up into the section's bottom padding -->
    <div aria-hidden="true" style="height:280px;background:linear-gradient(to bottom,var(--color-cream) 0%,var(--color-cream) 20%,var(--color-marigold) 100%);margin-top:-80px;position:relative;z-index:0;pointer-events:none;"></div>
    <BookingSection />
    <!-- marigold → deep -->
    <div aria-hidden="true" style="height:280px;background:linear-gradient(to bottom,var(--color-marigold) 0%,var(--color-deep) 100%);margin-top:-1px;pointer-events:none;"></div>
  </main>
  <Footer />
</Layout>
