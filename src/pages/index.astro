---
import Layout from '../layouts/Layout.astro'
import Preloader from '../components/Preloader.astro'
import Navbar from '../components/Navbar.astro'
import HeroSection from '../components/HeroSection.astro'
import TrustBar from '../components/TrustBar.astro'
import ChapterOne from '../components/ChapterOne.astro'
import ChapterTwo from '../components/ChapterTwo.astro'
import ChapterThree from '../components/ChapterThree.astro'
import FlagInterstitial from '../components/FlagInterstitial.astro'
import TestimonialsSection from '../components/TestimonialsSection.astro'
import BookingSection from '../components/BookingSection.astro'
import Footer from '../components/Footer.astro'
import ScrollAnimations from '../components/ScrollAnimations.astro'
---
<Layout
  title="French Tutoring for Kids"
  description="One-to-one online French lessons for children from Junior Kindergarten through Grade 5. Book a free intro call with Naya today."
>
  <Preloader />
  <ScrollAnimations />
  <Navbar />
  <main id="main-content">
    <HeroSection />
    <TrustBar />
    <ChapterOne />
    <ChapterTwo />
    <ChapterThree />
    <FlagInterstitial />
    <TestimonialsSection />
    <div class="sg sg-cream-marigold" aria-hidden="true"></div>
    <BookingSection />
    <div class="sg sg-marigold-deep" aria-hidden="true"></div>
  </main>
  <Footer />
</Layout>

<style>
  /*
   * Smooth section-to-section gradients.
   *
   * Technique: "easing gradient" — multiple stops at ease-in-out positions
   * combined with `color-mix(in oklch)` interpolation.
   * OKLCH avoids the muddy dark midpoints that RGB linear-gradient produces
   * between a dark colour and a vivid one (same reason Photoshop looks smoother).
   * Supported: Chrome 111+, Firefox 113+, Safari 16.2+.
   */
  .sg {
    height: 300px;
    pointer-events: none;
    position: relative;
    z-index: 0;
  }

  /* Testimonials (cream) → Booking (marigold)
     Held at cream for first 15%, then eased in via OKLCH */
  .sg-cream-marigold {
    margin-top: -80px;
    background: linear-gradient(to bottom,
      var(--color-cream)                                               0%,
      var(--color-cream)                                              15%,
      color-mix(in oklch, var(--color-marigold)  6%, var(--color-cream)) 24%,
      color-mix(in oklch, var(--color-marigold) 18%, var(--color-cream)) 34%,
      color-mix(in oklch, var(--color-marigold) 38%, var(--color-cream)) 45%,
      color-mix(in oklch, var(--color-marigold) 62%, var(--color-cream)) 57%,
      color-mix(in oklch, var(--color-marigold) 82%, var(--color-cream)) 69%,
      color-mix(in oklch, var(--color-marigold) 94%, var(--color-cream)) 81%,
      var(--color-marigold)                                          100%
    );
  }

  /* Booking (marigold) → Footer (deep dark) — full ease-in-out across 300px */
  .sg-marigold-deep {
    margin-top: -1px;
    background: linear-gradient(to bottom,
      var(--color-marigold)                                           0%,
      color-mix(in oklch, var(--color-deep)  6%, var(--color-marigold)) 19%,
      color-mix(in oklch, var(--color-deep) 18%, var(--color-marigold)) 32%,
      color-mix(in oklch, var(--color-deep) 38%, var(--color-marigold)) 45%,
      color-mix(in oklch, var(--color-deep) 62%, var(--color-marigold)) 57%,
      color-mix(in oklch, var(--color-deep) 82%, var(--color-marigold)) 70%,
      color-mix(in oklch, var(--color-deep) 94%, var(--color-marigold)) 83%,
      var(--color-deep)                                              100%
    );
  }
</style>
