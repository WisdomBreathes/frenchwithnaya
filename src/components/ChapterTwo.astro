---
---
<section id="who-its-for" class="chapter-two" aria-labelledby="ch2-heading">
  <div class="ch2-header">
    <p class="chapter-label">Who It's For</p>
    <h2 id="ch2-heading" class="chapter-title" data-reveal>
      Every session fits exactly where your child is.
    </h2>
  </div>

  <div class="cards-scroll-wrap" role="region" aria-label="Age groups — scroll to see all">
    <div class="cards-track" role="list">

      <article class="age-card card-peach" role="listitem">
        <div class="card-top">
          <div class="card-age-range">JK &amp; Grade 1</div>
          <div class="card-ages">Ages<br/>4–6</div>
        </div>
        <h3 class="card-title">Building the first spark</h3>
        <p class="card-desc">
          Colours, numbers, animals, songs, and basic greetings — taught through games and lots of repetition. The goal is joy, not perfection.
        </p>
        <ul class="card-topics" aria-label="Topics covered">
          <li>Colours &amp; numbers</li>
          <li>Animals &amp; body parts</li>
          <li>Basic greetings</li>
          <li>French songs</li>
        </ul>
      </article>

      <article class="age-card card-blue" role="listitem">
        <div class="card-top">
          <div class="card-age-range">Grade 2–3</div>
          <div class="card-ages">Ages<br/>7–9</div>
        </div>
        <h3 class="card-title">From words to sentences</h3>
        <p class="card-desc">
          Short stories, simple sentences, reading out loud, asking questions. Building confidence to actually say something in French.
        </p>
        <ul class="card-topics" aria-label="Topics covered">
          <li>Simple sentences</li>
          <li>Reading short texts</li>
          <li>Question words</li>
          <li>Stories &amp; games</li>
        </ul>
      </article>

      <article class="age-card card-moss" role="listitem">
        <div class="card-top">
          <div class="card-age-range">Grade 4–5</div>
          <div class="card-ages">Ages<br/>10–11</div>
        </div>
        <h3 class="card-title">Real conversation, real confidence</h3>
        <p class="card-desc">
          Grammar foundations, writing practice, and the satisfaction of saying something in French and being understood.
        </p>
        <ul class="card-topics" aria-label="Topics covered">
          <li>Conversation practice</li>
          <li>Writing &amp; grammar</li>
          <li>Reading comprehension</li>
          <li>Building confidence</li>
        </ul>
      </article>

    </div>
    <!-- Scroll hint on mobile -->
    <p class="scroll-hint" aria-hidden="true">Scroll to see all age groups →</p>
  </div>
</section>

<style>
  .chapter-two {
    padding: clamp(5rem, 10vw, 9rem) 0;
    background: var(--color-cream);
    overflow: hidden;
  }
  .ch2-header {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
    margin-bottom: clamp(3rem, 5vw, 4rem);
  }
  .chapter-label {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-marigold);
    margin-bottom: var(--space-6);
  }
  .chapter-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--text-h1);
    color: var(--color-ink);
    max-width: 560px;
  }

  /* Scroll container */
  .cards-scroll-wrap {
    position: relative;
  }
  .cards-track {
    display: grid;
    grid-template-columns: repeat(3, minmax(300px, 1fr));
    gap: clamp(1rem, 2vw, 1.5rem);
    padding: 0 clamp(1.5rem, 5vw, 4rem);
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Cards */
  .age-card {
    border-radius: 6px;
    padding: clamp(2rem, 3.5vw, 2.75rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .age-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(26, 23, 20, 0.1);
  }

  /* Card colour variants */
  .card-peach {
    background: #F5C9A0;  /* warm amber-peach — energetic for youngest kids */
    color: #3D1F00;
  }
  .card-blue {
    background: #A8C8E8;  /* cornflower blue — calm confidence */
    color: #0D2640;
  }
  .card-moss {
    background: #A8C9A0;  /* fresh moss — growth, progress */
    color: #0F2810;
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .card-age-range {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.65;
  }
  .card-ages {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1;
    letter-spacing: -0.02em;
    text-align: right;
  }
  .card-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-h3);
    line-height: 1.2;
    letter-spacing: -0.01em;
    border-top: 1.5px solid currentColor;
    padding-top: var(--space-4);
    opacity: 0.9;
  }
  .card-desc {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: 1.7;
    opacity: 0.8;
    flex: 1;
  }
  .card-topics {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border-top: 1px solid currentColor;
    padding-top: var(--space-4);
    margin-top: auto;
    opacity: 0.7;
  }
  .card-topics li {
    font-family: var(--font-body);
    font-size: var(--text-small);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .card-topics li::before {
    content: '';
    display: inline-block;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
    opacity: 0.7;
  }

  .scroll-hint {
    display: none;
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--text-small);
    color: rgba(26, 23, 20, 0.45);
    margin-top: 1.25rem;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  /* Tablet: scroll with snap */
  @media (max-width: 900px) {
    .cards-track {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 1rem;
      padding: 0 clamp(1.5rem, 5vw, 4rem);
      padding-right: clamp(3rem, 10vw, 6rem);
      max-width: none;
    }
    .cards-track::-webkit-scrollbar { display: none; }
    .age-card {
      flex: 0 0 min(85vw, 360px);
      scroll-snap-align: start;
    }
    .scroll-hint { display: block; }
  }

  @media (max-width: 480px) {
    .age-card { flex: 0 0 88vw; }
  }
</style>

<script>
  import gsap from 'gsap'
  import ScrollTrigger from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (prefersReduced) return

    // Stagger cards in on scroll
    gsap.from('.age-card', {
      opacity: 0,
      y: 40,
      duration: 0.65,
      ease: 'power3.out',
      stagger: 0.15,
      scrollTrigger: {
        trigger: '.cards-track',
        start: 'top 80%',
        once: true
      }
    })
  })
</script>
