---
---
<section id="who-its-for" class="chapter-two" aria-labelledby="ch2-heading">
  <div class="ch2-header">
    <p class="chapter-label">
      <span class="t-en">Who It's For</span>
      <span class="t-fr">Pour qui ?</span>
    </p>
    <h2 id="ch2-heading" class="chapter-title" data-reveal>
      <span class="t-en">Every session fits exactly where your child is.</span>
      <span class="t-fr">Chaque cours s'adapte exactement là où en est votre enfant.</span>
    </h2>
  </div>

  <div class="cards-scroll-wrap" role="region" aria-label="Age groups">
    <div class="cards-track" role="list">

      <article class="age-card card-peach" role="listitem">
        <div class="card-top">
          <div class="card-age-range">
            <span class="t-en">JK &amp; Grade 1</span>
            <span class="t-fr">Maternelle &amp; 1re année</span>
          </div>
          <div class="card-ages">
            <span class="t-en">Ages<br/>4–6</span>
            <span class="t-fr">4–6<br/>ans</span>
          </div>
        </div>
        <h3 class="card-title">
          <span class="t-en">Building the first spark</span>
          <span class="t-fr">Les premières étincelles</span>
        </h3>
        <p class="card-desc">
          <span class="t-en">Colours, numbers, animals, songs, and basic greetings. Taught through games and plenty of repetition. The goal is joy, not perfection.</span>
          <span class="t-fr">Couleurs, chiffres, animaux, chansons et formules de base. Appris par le jeu et beaucoup de répétition. L'objectif : la joie, pas la perfection.</span>
        </p>
        <ul class="card-topics" aria-label="Topics covered">
          <li><span class="t-en">Colours &amp; numbers</span><span class="t-fr">Couleurs &amp; chiffres</span></li>
          <li><span class="t-en">Animals &amp; body parts</span><span class="t-fr">Animaux &amp; corps humain</span></li>
          <li><span class="t-en">Basic greetings</span><span class="t-fr">Formules de politesse</span></li>
          <li><span class="t-en">French songs</span><span class="t-fr">Chansons françaises</span></li>
        </ul>
      </article>

      <article class="age-card card-blue" role="listitem">
        <div class="card-top">
          <div class="card-age-range">
            <span class="t-en">Grade 2–3</span>
            <span class="t-fr">2e–3e année</span>
          </div>
          <div class="card-ages">
            <span class="t-en">Ages<br/>7–9</span>
            <span class="t-fr">7–9<br/>ans</span>
          </div>
        </div>
        <h3 class="card-title">
          <span class="t-en">From words to sentences</span>
          <span class="t-fr">Des mots aux phrases</span>
        </h3>
        <p class="card-desc">
          <span class="t-en">Short stories, simple sentences, reading out loud, asking questions. Building confidence to actually say something in French.</span>
          <span class="t-fr">Petites histoires, phrases simples, lecture à voix haute, poser des questions. Gagner la confiance pour vraiment dire quelque chose en français.</span>
        </p>
        <ul class="card-topics" aria-label="Topics covered">
          <li><span class="t-en">Simple sentences</span><span class="t-fr">Phrases simples</span></li>
          <li><span class="t-en">Reading short texts</span><span class="t-fr">Lire des textes courts</span></li>
          <li><span class="t-en">Question words</span><span class="t-fr">Mots interrogatifs</span></li>
          <li><span class="t-en">Stories &amp; games</span><span class="t-fr">Histoires &amp; jeux</span></li>
        </ul>
      </article>

      <article class="age-card card-moss" role="listitem">
        <div class="card-top">
          <div class="card-age-range">
            <span class="t-en">Grade 4–5</span>
            <span class="t-fr">4e–5e année</span>
          </div>
          <div class="card-ages">
            <span class="t-en">Ages<br/>10–11</span>
            <span class="t-fr">10–11<br/>ans</span>
          </div>
        </div>
        <h3 class="card-title">
          <span class="t-en">Real conversation, real confidence</span>
          <span class="t-fr">De vraies conversations, une vraie assurance</span>
        </h3>
        <p class="card-desc">
          <span class="t-en">Grammar foundations, writing practice, and the satisfaction of saying something in French and being understood.</span>
          <span class="t-fr">Les bases de la grammaire, de l'écriture, et la satisfaction de dire quelque chose en français et d'être compris.</span>
        </p>
        <ul class="card-topics" aria-label="Topics covered">
          <li><span class="t-en">Conversation practice</span><span class="t-fr">Conversation pratique</span></li>
          <li><span class="t-en">Writing &amp; grammar</span><span class="t-fr">Écriture &amp; grammaire</span></li>
          <li><span class="t-en">Reading comprehension</span><span class="t-fr">Compréhension écrite</span></li>
          <li><span class="t-en">Building confidence</span><span class="t-fr">Développer l'assurance</span></li>
        </ul>
      </article>

    </div>
    <!-- Scroll hint on mobile -->
    <p class="scroll-hint" aria-hidden="true">
      <span class="t-en">Scroll to see all age groups →</span>
      <span class="t-fr">Défiler pour voir tous les groupes d'âge →</span>
    </p>
  </div>
</section>

<style>
  .chapter-two {
    padding: clamp(5rem, 10vw, 9rem) 0;
    background: var(--color-cream);
    overflow: hidden;
  }
  .ch2-header {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
    margin-bottom: clamp(3rem, 5vw, 4rem);
  }
  .chapter-label {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-marigold);
    margin-bottom: var(--space-6);
  }
  .chapter-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--text-h1);
    color: var(--color-ink);
    max-width: 560px;
  }

  /* Scroll container */
  .cards-scroll-wrap {
    position: relative;
  }
  .cards-track {
    display: grid;
    grid-template-columns: repeat(3, minmax(300px, 1fr));
    gap: clamp(1rem, 2vw, 1.5rem);
    padding: 0 clamp(1.5rem, 5vw, 4rem);
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Cards */
  .age-card {
    border-radius: 6px;
    padding: clamp(2rem, 3.5vw, 2.75rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .age-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(var(--color-ink-rgb), 0.1);
  }

  /* Card colour variants */
  .card-peach {
    background: #F5C9A0;  /* warm amber-peach — energetic for youngest kids */
    color: #3D1F00;
  }
  .card-blue {
    background: #A8C8E8;  /* cornflower blue — calm confidence */
    color: #0D2640;
  }
  .card-moss {
    background: #A8C9A0;  /* fresh moss — growth, progress */
    color: #0F2810;
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .card-age-range {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.65;
  }
  .card-ages {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1;
    letter-spacing: -0.02em;
    text-align: right;
    white-space: nowrap;
  }
  .card-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-h3);
    line-height: 1.2;
    letter-spacing: -0.01em;
    border-top: 1.5px solid currentColor;
    padding-top: var(--space-4);
    opacity: 0.9;
  }
  .card-desc {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: 1.7;
    opacity: 0.8;
    flex: 1;
  }
  .card-topics {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border-top: 1px solid currentColor;
    padding-top: var(--space-4);
    margin-top: auto;
    opacity: 0.7;
  }
  .card-topics li {
    font-family: var(--font-body);
    font-size: var(--text-small);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .card-topics li::before {
    content: '';
    display: inline-block;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
    opacity: 0.7;
  }

  .scroll-hint {
    display: none;
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--text-small);
    color: rgba(var(--color-ink-rgb), 0.45);
    margin-top: 1.25rem;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  /* Tablet/mobile: native horizontal scroll with snap */
  @media (max-width: 900px) {
    .chapter-two { overflow: visible; }
    .cards-scroll-wrap { overflow: hidden; }
    .cards-track {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 1rem;
      /* leading padding aligns first card with page margin */
      padding: 0.25rem clamp(1.5rem, 5vw, 4rem);
      /* trailing padding lets last card breathe before edge */
      padding-right: clamp(3rem, 10vw, 6rem);
      max-width: none;
      /* snap origin matches leading padding */
      scroll-padding-left: clamp(1.5rem, 5vw, 4rem);
    }
    .cards-track::-webkit-scrollbar { display: none; }
    .age-card {
      flex: 0 0 min(80vw, 340px);
      scroll-snap-align: start;
    }
    .scroll-hint { display: block; }
  }

  @media (max-width: 480px) {
    .age-card {
      /* fills viewport minus the leading padding on both sides */
      flex: 0 0 calc(100vw - clamp(3rem, 10vw, 8rem));
    }
  }
</style>

<script>
  import gsap from 'gsap'
  import ScrollTrigger from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (prefersReduced) return

    // Stagger cards in on scroll
    gsap.from('.age-card', {
      opacity: 0,
      y: 40,
      duration: 0.65,
      ease: 'power3.out',
      stagger: 0.15,
      scrollTrigger: {
        trigger: '.cards-track',
        start: 'top 80%',
        once: true
      }
    })
  })
</script>
