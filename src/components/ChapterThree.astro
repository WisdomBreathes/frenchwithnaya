---
---
<section id="meet-naya" class="chapter-three" aria-labelledby="ch3-heading">
  <div class="container">
    <p class="chapter-label">
      <span class="t-en">Meet Naya</span>
      <span class="t-fr">Rencontrez Naya</span>
    </p>

    <div class="ch3-grid">
      <!-- Photo side -->
      <div class="ch3-photo-col" aria-hidden="true">
        <div class="ch3-photo-frame">
          <div class="ch3-photo-circle">
            <picture>
              <source type="image/webp"
                srcset="/frenchwithnaya/images/naya-about-800w.webp 800w, /frenchwithnaya/images/naya-about-1400w.webp 1400w"
                sizes="clamp(240px, 28vw, 420px)" />
              <img src="/frenchwithnaya/images/naya-about-800w.webp"
                alt="Naya in Paris"
                width="800" height="450"
                loading="lazy"
                style="width:100%;height:100%;object-fit:cover;object-position:center top;" />
            </picture>
          </div>
          <!-- Decorative accent -->
          <div class="photo-accent"></div>
        </div>
      </div>

      <!-- Text side -->
      <div class="ch3-text-col">
        <h2 id="ch3-heading" class="ch3-title">
          <span class="t-en">She learned French out of pure love for it. Now she passes that on.</span>
          <span class="t-fr">Elle a appris le français par pure passion. Aujourd'hui, elle le transmet.</span>
        </h2>

        <blockquote class="ch3-quote" data-reveal>
          <p class="t-en">"Every child learns differently. My job is to figure out how your child thinks — and then teach French in a way that actually makes sense to them."</p>
          <p class="t-fr">« Chaque enfant apprend différemment. Mon rôle, c'est de comprendre comment votre enfant pense, puis de lui enseigner le français d'une façon qui lui parle vraiment. »</p>
          <cite>— Naya</cite>
        </blockquote>

        <div class="ch3-credentials" data-reveal>
          <div class="credential">
            <span class="credential-dot" aria-hidden="true"></span>
            <p class="t-en">Science-educated. She brings genuine structure and method to every lesson, not just enthusiasm for the subject.</p>
            <p class="t-fr">Formée en sciences. Elle apporte une vraie structure et une vraie méthode à chaque cours, pas seulement de l'enthousiasme.</p>
          </div>
          <div class="credential">
            <span class="credential-dot" aria-hidden="true"></span>
            <p class="t-en">Fell in love with French young and pursued it seriously. She knows firsthand what it actually takes to learn it.</p>
            <p class="t-fr">Tombée amoureuse du français très tôt et l'a poursuivi sérieusement. Elle sait par expérience ce qu'il faut vraiment pour l'apprendre.</p>
          </div>
          <div class="credential">
            <span class="credential-dot" aria-hidden="true"></span>
            <p class="t-en">Fluent in English and French, switching between them as needed so your child is never lost.</p>
            <p class="t-fr">Parfaitement bilingue, elle passe de l'anglais au français selon les besoins pour que votre enfant ne soit jamais perdu.</p>
          </div>
          <div class="credential">
            <span class="credential-dot" aria-hidden="true"></span>
            <p class="t-en">Patient and clear, with a strong background in communication. She's genuinely good at reading what a child needs in the moment.</p>
            <p class="t-fr">Patiente et claire, avec un solide bagage en communication. Elle sait instinctivement ce dont un enfant a besoin sur le moment.</p>
          </div>
        </div>

        <div class="ch3-cta" data-reveal>
          <a
            href="https://cal.com/naya-831b2r/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            <span class="t-en">Book time with Naya</span>
            <span class="t-fr">Réserver un cours avec Naya</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .chapter-three {
    padding: clamp(5rem, 10vw, 9rem) 0;
    background: var(--color-cream);
  }
  /* .container and .chapter-label are global utilities in global.css */
  .ch3-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
    margin-top: 0;
  }
  .ch3-photo-col { position: relative; }
  .ch3-photo-frame {
    position: relative;
    display: inline-block;
  }
  .ch3-photo-circle {
    width: clamp(240px, 28vw, 420px);
    height: clamp(240px, 28vw, 420px);
    border-radius: 50%;
    background: var(--color-peach);
    overflow: hidden;
    position: relative;
    z-index: 1;
  }
  .photo-accent {
    position: absolute;
    bottom: -2rem;
    right: -2rem;
    width: 60%;
    height: 60%;
    border: 2px solid var(--color-marigold);
    border-radius: 50%;
    opacity: 0.25;
    z-index: 0;
  }
  .ch3-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--text-h1);
    color: var(--color-ink);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-8);
  }
  .ch3-quote {
    border-left: 3px solid var(--color-marigold);
    padding-left: var(--space-6);
    margin: 0 0 var(--space-8);
  }
  .ch3-quote p {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--text-h3);
    color: var(--color-ink);
    line-height: 1.5;
    margin-bottom: var(--space-2);
  }
  .ch3-quote cite {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 500;
    color: rgba(var(--color-ink-rgb), 0.55);
    font-style: normal;
  }
  .ch3-credentials {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }
  .credential {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }
  .credential-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--color-marigold);
    flex-shrink: 0;
    margin-top: 0.6em;
  }
  .credential p {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: rgba(var(--color-ink-rgb), 0.75);
    line-height: 1.65;
  }
  /* .btn-primary is a global utility in global.css */

  @media (max-width: 900px) {
    .ch3-grid {
      grid-template-columns: 1fr;
    }
    .ch3-photo-col {
      display: flex;
      justify-content: center;
    }
    .ch3-photo-circle {
      width: 200px;
      height: 200px;
    }
    .ch3-photo-circle img {
      object-position: 30% center;
    }
  }
</style>

<script>
  import gsap from 'gsap'
  import ScrollTrigger from 'gsap/ScrollTrigger'
  import { SplitText } from 'gsap/SplitText'

  gsap.registerPlugin(ScrollTrigger, SplitText)

  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (prefersReduced) return

    // ch3-title does NOT use [data-reveal] — it owns its full entrance via SplitText.
    // fonts.ready ensures Fraunces is loaded before SplitText measures line positions.
    // If SplitText runs with the fallback font, line breaks are wrong and text
    // overflows its containers when Fraunces swaps in.
    const titleEl = document.querySelector<HTMLElement>('.ch3-title')
    if (titleEl) {
      gsap.set(titleEl, { opacity: 0 })
      document.fonts.ready.then(() => {
        const split = SplitText.create(titleEl, { type: 'lines', autoSplit: true })
        gsap.from(split.lines, {
          opacity: 0,
          y: 30,
          duration: 0.7,
          stagger: 0.12,
          ease: 'power3.out',
          clearProps: 'opacity,transform',
          scrollTrigger: {
            trigger: titleEl,
            start: 'top 80%',
            once: true,
            onEnter: () => gsap.set(titleEl, { opacity: 1 })
          }
        })
      })
    }
  })
</script>
