---
---
<section id="meet-naya" class="chapter-three" aria-labelledby="ch3-heading">
  <div class="container">
    <p class="chapter-label">Meet Naya</p>

    <div class="ch3-grid">
      <!-- Photo side -->
      <div class="ch3-photo-col" aria-hidden="true">
        <div class="ch3-photo-frame">
          <div class="ch3-photo-circle">
            <span class="photo-initial">N</span>
          </div>
          <!-- Decorative accent -->
          <div class="photo-accent"></div>
        </div>
      </div>

      <!-- Text side -->
      <div class="ch3-text-col">
        <h2 id="ch3-heading" class="ch3-title" data-reveal>
          She learned French out of pure love for it. Now she passes that on.
        </h2>

        <blockquote class="ch3-quote" data-reveal>
          <p>"French found me when I was young, and I never let it go. That's the energy I bring to every lesson."</p>
          <cite>— Naya</cite>
        </blockquote>

        <div class="ch3-credentials" data-reveal>
          <div class="credential">
            <span class="credential-dot" aria-hidden="true"></span>
            <p>Fell in love with French as a child and pursued it with real dedication — she knows exactly what it takes to learn it from scratch</p>
          </div>
          <div class="credential">
            <span class="credential-dot" aria-hidden="true"></span>
            <p>Has worked with young children across a range of ages and learning styles</p>
          </div>
          <div class="credential">
            <span class="credential-dot" aria-hidden="true"></span>
            <p>Fluent in both English and French — she explains things in the language your child needs in the moment</p>
          </div>
          <div class="credential">
            <span class="credential-dot" aria-hidden="true"></span>
            <p>Every lesson plan is written fresh for that child — no one-size-fits-all approach</p>
          </div>
        </div>

        <div class="ch3-cta" data-reveal>
          <a
            href="https://cal.com/naya-831b2r/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            Book time with Naya
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .chapter-three {
    padding: clamp(5rem, 10vw, 9rem) 0;
    background: var(--color-cream);
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }
  .chapter-label {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-marigold);
    margin-bottom: var(--space-6);
  }
  .ch3-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
    margin-top: 0;
  }
  .ch3-photo-col { position: relative; }
  .ch3-photo-frame {
    position: relative;
    display: inline-block;
  }
  .ch3-photo-circle {
    width: clamp(240px, 28vw, 420px);
    height: clamp(240px, 28vw, 420px);
    border-radius: 50%;
    background: var(--color-peach);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }
  .photo-initial {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(6rem, 10vw, 10rem);
    color: var(--color-marigold);
    font-weight: 700;
    line-height: 1;
  }
  .photo-accent {
    position: absolute;
    bottom: -2rem;
    right: -2rem;
    width: 60%;
    height: 60%;
    border: 2px solid var(--color-marigold);
    border-radius: 50%;
    opacity: 0.25;
    z-index: 0;
  }
  .ch3-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--text-h1);
    color: var(--color-ink);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-8);
  }
  .ch3-quote {
    border-left: 3px solid var(--color-marigold);
    padding-left: var(--space-6);
    margin: 0 0 var(--space-8);
  }
  .ch3-quote p {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--text-h3);
    color: var(--color-ink);
    line-height: 1.5;
    margin-bottom: var(--space-2);
  }
  .ch3-quote cite {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 500;
    color: rgba(26, 23, 20, 0.55);
    font-style: normal;
  }
  .ch3-credentials {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }
  .credential {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }
  .credential-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--color-marigold);
    flex-shrink: 0;
    margin-top: 0.6em;
  }
  .credential p {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: rgba(26, 23, 20, 0.75);
    line-height: 1.65;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 1rem 2rem;
    background: var(--color-marigold);
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(232, 160, 32, 0.4);
  }

  @media (max-width: 900px) {
    .ch3-grid {
      grid-template-columns: 1fr;
    }
    .ch3-photo-col {
      display: flex;
      justify-content: center;
    }
    .ch3-photo-circle {
      width: 200px;
      height: 200px;
    }
    .photo-initial { font-size: 5rem; }
  }
</style>

<script>
  import gsap from 'gsap'
  import ScrollTrigger from 'gsap/ScrollTrigger'
  import { SplitText } from 'gsap/SplitText'

  gsap.registerPlugin(ScrollTrigger, SplitText)

  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (prefersReduced) return

    // Line-by-line reveal on chapter title
    const title = document.querySelector('.ch3-title')
    if (title) {
      const split = SplitText.create('.ch3-title', { type: 'lines', autoSplit: true })
      gsap.from(split.lines, {
        opacity: 0,
        y: 30,
        duration: 0.7,
        stagger: 0.12,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.ch3-title',
          start: 'top 80%'
        }
      })
    }
  })
</script>
