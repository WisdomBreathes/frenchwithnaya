---
---
<section id="book" class="booking-section" aria-labelledby="booking-heading">
  <div class="container">
    <div class="booking-header" data-reveal>
      <p class="chapter-label-light">
        <span class="t-en">Let's Get Started</span>
        <span class="t-fr">Commençons</span>
      </p>
      <h2 id="booking-heading" class="booking-title">
        <span class="t-en">Ready to book?</span>
        <span class="t-fr">Prêt à vous lancer ?</span>
      </h2>
      <p class="booking-sub">
        <span class="t-en">Free intro call. No commitment. Just a chance to meet Naya and see if it's the right fit.</span>
        <span class="t-fr">Appel de découverte gratuit. Sans engagement. Juste l'occasion de rencontrer Naya et de voir si c'est fait pour vous.</span>
      </p>
    </div>

    <div class="booking-grid">
      <!-- Cal.com embed -->
      <div class="booking-cal" data-reveal>
        <h3 class="booking-col-title">
          <span class="t-en">Book a call directly</span>
          <span class="t-fr">Réserver directement</span>
        </h3>
        <div
          class="cal-embed-wrap"
          data-cal-link="naya-831b2r/30min"
          data-cal-namespace="french-with-naya"
          data-cal-config='{"layout":"month_view"}'
          aria-label="Cal.com booking calendar"
        ></div>
        <p class="cal-fallback">
          <span class="t-en">Can't see the calendar?</span>
          <span class="t-fr">Vous ne voyez pas le calendrier ?</span>
          <a
            href="https://cal.com/naya-831b2r/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="cal-fallback-link"
          >
            <span class="t-en">Book directly on Cal.com →</span>
            <span class="t-fr">Réserver sur Cal.com →</span>
          </a>
        </p>
      </div>

      <!-- Divider -->
      <div class="booking-or" aria-hidden="true">
        <span class="or-line"></span>
        <span class="or-text">or</span>
        <span class="or-line"></span>
      </div>

      <!-- Web3Forms contact form -->
      <div class="booking-form" data-reveal>
        <h3 class="booking-col-title">
          <span class="t-en">Send a message</span>
          <span class="t-fr">Envoyer un message</span>
        </h3>
        <form
          id="contact-form"
          method="POST"
          action="https://api.web3forms.com/submit"
          aria-label="Contact form"
          novalidate
        >
          <!-- Web3Forms config -->
          <input type="hidden" name="access_key" value="9007954b-92d1-4aa3-8e94-59e44a056b67" />
          <input type="hidden" name="redirect" value="https://wisdombreathes.github.io/frenchwithnaya/thank-you/" />
          <input type="hidden" name="subject" value="New enquiry — French with Naya" />
          <!-- Honeypot -->
          <div style="position:absolute;left:-9999px;top:-9999px;" aria-hidden="true">
            <label for="gotcha">Leave this empty</label>
            <input type="text" id="gotcha" name="_gotcha" tabindex="-1" autocomplete="off" />
          </div>

          <div class="form-group">
            <label class="form-label" for="name">
              <span class="t-en">Your name</span>
              <span class="t-fr">Votre prénom</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              class="form-input"
              required
              autocomplete="name"
              placeholder="e.g. Sarah Chen"
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="email">
              <span class="t-en">Email address</span>
              <span class="t-fr">Adresse courriel</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              required
              autocomplete="email"
              placeholder="you@example.com"
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="grade">
              <span class="t-en">Child's age / grade</span>
              <span class="t-fr">Âge / niveau de l'enfant</span>
            </label>
            <select id="grade" name="grade" class="form-input" required>
              <option value="" disabled selected>Select a grade range</option>
              <option value="JK–Grade 1 (ages 4–6)">JK–Grade 1 (ages 4–6)</option>
              <option value="Grade 2–3 (ages 7–9)">Grade 2–3 (ages 7–9)</option>
              <option value="Grade 4–5 (ages 10–11)">Grade 4–5 (ages 10–11)</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="message">
              <span class="t-en">Your message</span>
              <span class="t-fr">Votre message</span>
            </label>
            <textarea
              id="message"
              name="message"
              class="form-input form-textarea"
              rows="4"
              required
              placeholder="Tell Naya a little about your child and what you're hoping for."
            ></textarea>
          </div>

          <div id="form-error" class="form-error" role="alert" aria-live="polite" hidden></div>

          <button type="submit" class="btn-submit" id="submit-btn">
            <span class="btn-label">
              <span class="t-en">Send message</span>
              <span class="t-fr">Envoyer le message</span>
            </span>
            <span class="btn-loading" hidden aria-hidden="true">
              <span class="t-en">Sending…</span>
              <span class="t-fr">Envoi en cours…</span>
            </span>
          </button>

          <p class="form-note">
            <span class="t-en">Naya typically replies within one business day.</span>
            <span class="t-fr">Naya répond généralement en un jour ouvrable.</span>
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .booking-section {
    background: var(--color-marigold);
    padding: clamp(5rem, 10vw, 9rem) 0;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }
  .booking-header {
    text-align: center;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }
  .chapter-label-light {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(var(--color-ink-rgb), 0.6);
    margin-bottom: var(--space-4);
  }
  .booking-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: var(--text-h1);
    color: var(--color-ink);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-4);
  }
  .booking-sub {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: rgba(var(--color-ink-rgb), 0.75);
  }
  .booking-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }
  .booking-col-title {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(var(--color-ink-rgb), 0.6);
    margin-bottom: var(--space-6);
  }
  .cal-embed-wrap {
    min-height: 500px;
    background: rgba(255, 255, 255, 0.4);
    border-radius: 4px;
  }
  .cal-fallback {
    margin-top: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-small);
    color: rgba(var(--color-ink-rgb), 0.6);
    text-align: center;
  }
  .cal-fallback-link {
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  /* Or divider */
  .booking-or {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding-top: 3rem;
  }
  .or-line {
    flex: 1;
    width: 1px;
    background: rgba(var(--color-ink-rgb), 0.2);
  }
  .or-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.25rem;
    color: rgba(var(--color-ink-rgb), 0.5);
  }
  /* Form */
  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }
  .form-label {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-ink);
  }
  .form-input {
    width: 100%;
    padding: 0.875rem 1rem;
    background: rgba(255, 255, 255, 0.6);
    border: 1.5px solid rgba(var(--color-ink-rgb), 0.2);
    border-radius: 2px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-ink);
    transition: border-color 0.2s ease, background 0.2s ease;
    -webkit-appearance: none;
  }
  .form-input:focus {
    outline: none;
    border-color: var(--color-ink);
    background: rgba(255, 255, 255, 0.9);
  }
  .form-textarea { resize: vertical; min-height: 120px; }
  .form-error {
    padding: 0.75rem 1rem;
    background: rgba(220, 60, 60, 0.12);
    border: 1px solid rgba(220, 60, 60, 0.3);
    border-radius: 2px;
    font-family: var(--font-body);
    font-size: var(--text-small);
    color: #c0392b;
    margin-bottom: var(--space-4);
  }
  .btn-submit {
    width: 100%;
    padding: 1rem 2rem;
    background: var(--color-ink);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    margin-bottom: var(--space-4);
  }
  .btn-submit:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(var(--color-ink-rgb), 0.3);
  }
  .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; }
  .form-note {
    font-family: var(--font-body);
    font-size: var(--text-small);
    color: rgba(var(--color-ink-rgb), 0.55);
    text-align: center;
  }

  @media (max-width: 768px) {
    input, textarea, select { font-size: 16px !important; }
    .booking-grid {
      grid-template-columns: 1fr;
    }
    .booking-or {
      flex-direction: row;
      padding: 0;
    }
    .or-line { height: 1px; flex: 1; }
  }
</style>

<script>
  // Cal.com embed
  ;(function (C: any, A: string, L: string) {
    let p = function (a: any, ar: any) { a.q.push(ar) }
    let d = C.document
    C.Cal =
      C.Cal ||
      function () {
        let cal = C.Cal
        let ar = arguments
        if (!cal.loaded) {
          cal.ns = {}
          cal.q = cal.q || []
          d.head.appendChild(d.createElement('script')).src = A
          cal.loaded = true
        }
        if (ar[0] === L) {
          const api: any = function () { p(api, arguments) }
          const namespace = ar[1]
          api.q = api.q || []
          if (typeof namespace === 'string') { cal.ns[namespace] = api; p(api, ar) }
          return
        }
        p(cal, ar)
      }
  })(window, 'https://app.cal.com/embed/embed.js', 'init')

  ;(window as any).Cal('init', 'french-with-naya', { origin: 'https://cal.com' })
  ;(window as any).Cal.ns['french-with-naya']('inline', {
    elementOrSelector: '[data-cal-namespace="french-with-naya"]',
    calLink: 'naya-831b2r/30min',
    layout: 'month_view'
  })

  // Web3Forms submission with URL spam guard
  const form = document.getElementById('contact-form') as HTMLFormElement
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement
  const errorDiv = document.getElementById('form-error') as HTMLElement
  const btnLabel = submitBtn?.querySelector('.btn-label') as HTMLElement
  const btnLoading = submitBtn?.querySelector('.btn-loading') as HTMLElement

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()

    const messageField = form.querySelector<HTMLTextAreaElement>('[name="message"]')
    const messageValue = messageField?.value || ''

    // Spam guard — reject messages containing URLs
    if (/https?:\/\/|www\./i.test(messageValue)) {
      errorDiv.textContent = 'Sorry, messages containing links cannot be submitted.'
      errorDiv.hidden = false
      return
    }

    errorDiv.hidden = true
    submitBtn.disabled = true
    btnLabel.hidden = true
    btnLoading.hidden = false

    try {
      const data = new FormData(form)
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: data
      })
      const json = await res.json()
      if (json.success) {
        window.location.href = 'https://wisdombreathes.github.io/frenchwithnaya/thank-you/'
      } else {
        throw new Error(json.message || 'Submission failed')
      }
    } catch (err) {
      errorDiv.textContent = 'Something went wrong. Please try again or email Naya directly.'
      errorDiv.hidden = false
      submitBtn.disabled = false
      btnLabel.hidden = false
      btnLoading.hidden = true
    }
  })
</script>
