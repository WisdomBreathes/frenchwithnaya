---
---
<section id="hero" aria-labelledby="hero-headline">
  <!-- Decorative background word -->
  <span class="bg-word" aria-hidden="true">merci</span>

  <div class="hero-inner">
    <div class="hero-content">
      <p class="hero-eyebrow">
        <span class="t-en">Online French Tutoring · JK–Grade 5</span>
        <span class="t-fr">Cours de français en ligne · Maternelle–5e année</span>
      </p>
      <h1 id="hero-headline" class="hero-headline">
        <span class="t-en">A French lesson they look forward to.</span>
        <span class="t-fr">Un cours de français qu'ils attendent avec impatience.</span>
      </h1>
      <p class="hero-sub">
        <span class="t-en">One-to-one French lessons for children from Junior Kindergarten through Grade 5, taught online by Naya. Warm, patient, and genuinely great with kids.</span>
        <span class="t-fr">Des cours de français individuels pour les enfants de la maternelle à la 5e année, dispensés en ligne par Naya. Chaleureuse, patiente, et vraiment douée avec les enfants.</span>
      </p>
      <a
        href="https://cal.com/naya-831b2r/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        <span class="t-en">Book a free intro call</span>
        <span class="t-fr">Réserver un appel gratuit</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Instructor photo -->
    <div class="hero-photo-wrap">
      <div class="hero-photo-circle">
        <picture>
          <source type="image/webp"
            srcset="/frenchwithnaya/images/naya-hero-320w-v2.webp 320w, /frenchwithnaya/images/naya-hero-600w-v2.webp 600w"
            sizes="(max-width: 768px) 160px, clamp(180px, 22vw, 280px)" />
          <img src="/frenchwithnaya/images/naya-hero-600w-v2.webp"
            alt="Naya, French tutor"
            width="600" height="800"
            fetchpriority="high" decoding="sync" loading="eager"
            style="width:100%;height:100%;object-fit:cover;object-position:62% 85%;" />
        </picture>
      </div>
      <div class="hero-photo-badge">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        <span class="t-en">Passionate<br/>learner</span>
        <span class="t-fr">Passionnée<br/>de français</span>
      </div>
    </div>
  </div>
</section>

<style>
  #hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    background: var(--color-cream);
    overflow: hidden;
    padding: 9rem 0 6rem;
  }
  .bg-word {
    position: absolute;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(10rem, 22vw, 20rem);
    color: var(--color-ink);
    opacity: 0.04;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    line-height: 1;
    bottom: -2rem;
    right: -2rem;
    z-index: 0;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 4rem;
  }
  .hero-content { max-width: 680px; }
  .hero-eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-marigold);
    margin-bottom: var(--space-6);
    opacity: 0;
    transform: translateY(16px);
  }
  .hero-headline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: var(--text-display);
    color: var(--color-ink);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-8);
    overflow: hidden;
    opacity: 0;
  }
  .hero-sub {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    color: rgba(var(--color-ink-rgb), 0.7);
    line-height: 1.7;
    margin-bottom: var(--space-12);
    max-width: 520px;
    opacity: 0;
    transform: translateY(16px);
  }
  /* Animation initial state — GSAP reveals this during the hero entrance */
  .btn-primary {
    opacity: 0;
    transform: translateY(16px);
  }
  .hero-photo-wrap {
    position: relative;
    flex-shrink: 0;
  }
  .hero-photo-circle {
    width: clamp(180px, 22vw, 280px);
    height: clamp(180px, 22vw, 280px);
    border-radius: 50%;
    background: var(--color-peach);
    overflow: hidden;
    border: 3px solid var(--color-chalk);
  }
  .hero-photo-badge {
    position: absolute;
    bottom: -1rem;
    left: -1.5rem;
    background: var(--color-ink);
    color: var(--color-cream);
    padding: 0.75rem 1rem;
    border-radius: 2px;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.4;
  }
  .hero-photo-badge svg { flex-shrink: 0; margin-top: 2px; color: var(--color-marigold); }

  @media (max-width: 768px) {
    #hero { padding: 8rem 0 5rem; }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .hero-photo-wrap {
      display: flex;
      justify-content: center;
      order: -1;
    }
    .hero-photo-circle {
      width: 160px;
      height: 160px;
    }
    .hero-photo-badge {
      font-size: 0.7rem;
      padding: 0.6rem 0.75rem;
      left: auto;
      right: -0.5rem;
      bottom: -0.75rem;
    }
  }
</style>

<script>
  import gsap from 'gsap'
  import { SplitText } from 'gsap/SplitText'
  import ScrollTrigger from 'gsap/ScrollTrigger'

  gsap.registerPlugin(SplitText, ScrollTrigger)

  window.__initAnimations = window.__initAnimations || function() {}

  const originalInit = window.__initAnimations

  window.__initAnimations = function() {
    originalInit()
    initHeroAnimations()
  }

  // Also init if preloader doesn't exist (fallback)
  document.addEventListener('DOMContentLoaded', () => {
    if (!document.getElementById('preloader')) {
      initHeroAnimations()
    }
  })

  function initHeroAnimations() {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (prefersReduced) {
      // Scope to hero section only — avoid touching other .btn-primary elements on the page
      document.querySelectorAll('.hero-eyebrow, .hero-sub, .hero-content .btn-primary').forEach(el => {
        (el as HTMLElement).style.opacity = '1';
        (el as HTMLElement).style.transform = 'none'
      })
      return
    }

    // SplitText measures line/word positions — must run after Fraunces has loaded.
    // If it runs with the fallback font, measurements are wrong and text bleeds its
    // containers when the real font swaps in.
    const headline = document.querySelector('.hero-headline') as HTMLElement
    if (headline) {
      headline.style.opacity = '1'
      document.fonts.ready.then(() => {
        SplitText.create('.hero-headline', {
          type: 'lines,words',
          autoSplit: true,
          onSplit(self: any) {
            return gsap.from(self.words, {
              yPercent: 110,
              opacity: 0,
              duration: 0.9,
              stagger: 0.04,
              ease: 'power3.out',
              clearProps: 'opacity,transform,yPercent'
            })
          }
        })
      })
    }

    // Stagger in eyebrow, sub, hero CTA only — do NOT target .btn-primary globally.
    // A global selector leaves inline transform styles that permanently break hover
    // effects on every other CTA button further down the page.
    gsap.to(['.hero-eyebrow', '.hero-sub', '.hero-content .btn-primary'], {
      opacity: 1,
      y: 0,
      duration: 0.7,
      stagger: 0.15,
      ease: 'power3.out',
      delay: 0.2,
      clearProps: 'opacity,transform'  // remove inline styles so CSS hover works normally
    })

    // Soft parallax on photo
    gsap.to('.hero-photo-wrap', {
      y: -60,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 1.5
      }
    })
  }
</script>
