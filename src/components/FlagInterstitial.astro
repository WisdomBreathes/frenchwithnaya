---
import libertePath from '../data/liberte-path.json'
---
<!--
  Pinned scroll section (250% of viewport height):
  0–40%   → blue/red panels slide in from edges, white fades in
  35–65%  → "liberté." is drawn stroke-by-stroke (stroke-dashoffset → 0)
            then fill fades in as the stroke fades out
  70–100% → everything fades back to cream
-->
<section class="flag-section" aria-hidden="true">
  <div class="flag-wrapper">
    <div class="flag-panel flag-blue"></div>
    <div class="flag-panel flag-white"></div>
    <div class="flag-panel flag-red"></div>

    <!-- Handwritten text via SVG stroke animation -->
    <div class="flag-text-wrap">
      <svg
        class="liberte-svg"
        viewBox={libertePath.viewBox}
        width={libertePath.width}
        height={libertePath.height}
        xmlns="http://www.w3.org/2000/svg"
        aria-label="liberté."
        role="img"
      >
        <!-- Fill layer — fades in after stroke completes -->
        <path
          class="liberte-fill"
          d={libertePath.pathD}
          fill="#1A1714"
          stroke="none"
          opacity="0"
        />
        <!-- Stroke layer — drawn left-to-right by dashoffset animation -->
        <path
          class="liberte-stroke"
          d={libertePath.pathD}
          fill="none"
          stroke="#1A1714"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </div>
  </div>
</section>

<style>
  .flag-section {
    position: relative;
    height: 100vh;
    overflow: hidden;
    background: #FAF7F2;
  }
  [data-theme="dark"] .flag-section {
    background: var(--color-cream);
  }
  .flag-wrapper {
    position: absolute;
    inset: 0;
    display: flex;
    overflow: hidden;
  }
  .flag-panel {
    flex: 1;
    height: 100%;
    will-change: transform;
  }
  .flag-blue  { background: #002395; }
  .flag-white { background: #F5F0E8; }
  .flag-red   { background: #ED2939; }

  .flag-text-wrap {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .liberte-svg {
    /* Scales to fill available width while keeping aspect ratio */
    width: clamp(320px, 70vw, 700px);
    height: auto;
    overflow: visible;
    opacity: 0;   /* JS fades this in with the flag */
  }

  /* stroke-dasharray / dashoffset set by JS once path length is measured */
  .liberte-stroke {
    stroke-dasharray: var(--path-len, 99999);
    stroke-dashoffset: var(--path-len, 99999);
  }

  @media (prefers-reduced-motion: reduce) {
    .flag-section { display: none; }
  }
</style>

<script>
  import gsap from 'gsap'
  import ScrollTrigger from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (prefersReduced) return

    const section  = document.querySelector('.flag-section') as HTMLElement
    const wrapper  = document.querySelector('.flag-wrapper') as HTMLElement
    const blue     = document.querySelector('.flag-blue') as HTMLElement
    const red      = document.querySelector('.flag-red') as HTMLElement
    const white    = document.querySelector('.flag-white') as HTMLElement
    const svg      = document.querySelector('.liberte-svg') as SVGSVGElement
    const stroke   = document.querySelector('.liberte-stroke') as SVGPathElement
    const fill     = document.querySelector('.liberte-fill') as SVGPathElement

    if (!section || !wrapper || !svg || !stroke || !fill) return

    // Measure total stroke path length so we can animate dashoffset
    const pathLen = stroke.getTotalLength()
    stroke.style.setProperty('--path-len', String(Math.ceil(pathLen)))
    stroke.style.strokeDasharray = String(Math.ceil(pathLen))
    stroke.style.strokeDashoffset = String(Math.ceil(pathLen))

    // Initial states
    gsap.set(blue,   { xPercent: -100 })
    gsap.set(red,    { xPercent:  100 })
    gsap.set(white,  { opacity: 0 })
    gsap.set(svg,    { opacity: 0 })
    gsap.set(fill,   { opacity: 0 })

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top top',
        end: '+=240%',
        pin: true,
        scrub: 0.5,
        anticipatePin: 1,
      }
    })

    tl
      // Phase 1 — flag assembles (0 → 0.25), snappier entry
      .to(blue,  { xPercent: 0, ease: 'power3.out' }, 0)
      .to(red,   { xPercent: 0, ease: 'power3.out' }, 0)
      .to(white, { opacity: 1, ease: 'power2.out' }, 0)

      // SVG fades in as flag finishes assembling
      .to(svg, { opacity: 1, duration: 0.03 }, 0.22)

      // Phase 2 — stroke draws (0.25 → 0.56), more scroll room for the writing
      .to(stroke, {
        strokeDashoffset: 0,
        ease: 'none',
      }, 0.25)

      // Phase 2b — fill blooms in as stroke nears end (0.52 → 0.58)
      .to(fill, { opacity: 1, ease: 'power2.in', duration: 0.06 }, 0.52)

      // Stroke dissolves once fill is solid (0.55 → 0.60)
      .to(stroke, { opacity: 0, ease: 'power2.in', duration: 0.05 }, 0.55)

      // Phase 3 — hold: let the completed word breathe (0.60 → 0.74)

      // Phase 4 — fade out (0.74 → 1.0)
      .to(wrapper, { opacity: 0, ease: 'power2.inOut' }, 0.74)
  })
</script>
