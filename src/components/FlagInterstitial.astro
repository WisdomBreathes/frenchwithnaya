<!--
  Pinned scroll section. As user scrolls through:
  0–40%   → blue and red panels slide in from edges, white fades in
  40–65%  → flag fully assembled, text appears
  70–100% → everything fades back to cream
-->
<section class="flag-section" aria-hidden="true">
  <div class="flag-wrapper">
    <div class="flag-panel flag-blue"></div>
    <div class="flag-panel flag-white"></div>
    <div class="flag-panel flag-red"></div>
    <p class="flag-text">liberté.</p>
  </div>
</section>

<style>
  .flag-section {
    position: relative;
    height: 100vh;
    overflow: hidden;
    background: var(--color-cream);
  }
  .flag-wrapper {
    position: absolute;
    inset: 0;
    display: flex;
    overflow: hidden;
  }
  .flag-panel {
    flex: 1;
    height: 100%;
    will-change: transform;
  }
  .flag-blue  { background: #002395; }
  .flag-white { background: #F5F0E8; } /* warm white — matches cream family */
  .flag-red   { background: #ED2939; }

  .flag-text {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(4rem, 12vw, 10rem);
    color: var(--color-cream);
    letter-spacing: -0.03em;
    pointer-events: none;
    mix-blend-mode: overlay;
    opacity: 0;
    transform: translateY(20px);
    text-shadow: 0 2px 40px rgba(0,0,0,0.15);
  }

  /* Reduced motion: skip the whole section */
  @media (prefers-reduced-motion: reduce) {
    .flag-section { display: none; }
  }
</style>

<script>
  import gsap from 'gsap'
  import ScrollTrigger from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  document.addEventListener('DOMContentLoaded', () => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (prefersReduced) return

    const section  = document.querySelector('.flag-section') as HTMLElement
    const wrapper  = document.querySelector('.flag-wrapper') as HTMLElement
    const blue     = document.querySelector('.flag-blue') as HTMLElement
    const red      = document.querySelector('.flag-red') as HTMLElement
    const white    = document.querySelector('.flag-white') as HTMLElement
    const text     = document.querySelector('.flag-text') as HTMLElement

    if (!section || !wrapper) return

    // Start state: blue off-screen left, red off-screen right, white invisible
    gsap.set(blue,  { xPercent: -100 })
    gsap.set(red,   { xPercent: 100 })
    gsap.set(white, { opacity: 0 })

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top top',
        end: '+=250%',   // scroll 2.5x the section height to pass through
        pin: true,
        scrub: 0.8,
        anticipatePin: 1,
      }
    })

    tl
      // Phase 1 — panels slide in together (0 → 0.4)
      .to(blue,  { xPercent: 0, ease: 'power2.out' }, 0)
      .to(red,   { xPercent: 0, ease: 'power2.out' }, 0)
      .to(white, { opacity: 1, ease: 'power2.out' }, 0)

      // Phase 2 — text fades in once flag is assembled (0.35 → 0.55)
      .to(text, { opacity: 1, y: 0, ease: 'power2.out' }, 0.35)

      // Phase 3 — hold (implicit — timeline just stays put)

      // Phase 4 — whole wrapper fades back to nothing (0.7 → 1.0)
      .to(wrapper, { opacity: 0, ease: 'power2.inOut' }, 0.7)
  })
</script>
